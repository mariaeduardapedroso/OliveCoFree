# Configurações do Banco de Dados Supabase
# Copie este arquivo para .env e preencha com suas credenciais

# URL de conexão do PostgreSQL (Supabase)
# Formato: postgresql://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@db.hjvomnrmsfyeiseuslds.supabase.co:5432/postgres

# Chave secreta para JWT (gere uma chave forte para produção)
SECRET_KEY=olhopavao-secret-key-change-in-production-2024

# URLs dos Microsserviços (Docker usa nomes dos containers)
# Local: http://127.0.0.1:8002 e http://127.0.0.1:8003
# Docker: http://microsservico-olho-pavao:8002 e http://microsservico-antracnose:8003
MICROSSERVICO_OLHO_PAVAO_URL=http://127.0.0.1:8002
MICROSSERVICO_ANTRACNOSE_URL=http://127.0.0.1:8003

# Frontend URL
FRONTEND_URL=http://localhost:5173
